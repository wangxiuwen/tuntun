{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tuntun",
  "version": "0.3.0",
  "identifier": "com.tuntun.menubar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "囤囤",
        "width": 700,
        "height": 620,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Utility",
    "shortDescription": "macOS 菜单栏图标囤起来",
    "longDescription": "囤囤 (Tuntun) — macOS 菜单栏图标收纳工具，像仓鼠囤食一样把不常用的图标囤进腮帮子。HiddenBar/Ice/Dozer 风格的 NSStatusItem 方案，无私有 API。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}